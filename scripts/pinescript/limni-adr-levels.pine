//@version=6
indicator("Limni ADR Levels", shorttitle="Limni ADR", overlay=true, format=format.price, max_boxes_count=500, max_lines_count=500, max_labels_count=200)

// ── Inputs ──────────────────────────────────────────────────────────────────
adrLookback   = input.int(10, "ADR Lookback (days)", minval=1, maxval=50)
adrMinDays    = input.int(5, "ADR Min Required Days", minval=1, maxval=50)
entryMultiple = input.float(1.0, "ADR Entry Multiple", minval=0.1, step=0.05)
tpMultiple    = input.float(0.25, "TP ADR Multiple", minval=0.05, step=0.05)
longPairs     = input.text_area("", "LONG Pairs (comma/newline)")
shortPairs    = input.text_area("", "SHORT Pairs (comma/newline)")
showTable     = input.bool(true, "Show Info Table")
showBoxes     = input.bool(true, "Show Trade Boxes")
showTradeLog  = input.bool(true, "Show Trade Log")
currentOnly   = input.bool(true, "Current Week Only")

periodBoxBg      = input.color(color.new(#2a2e39, 70), "Period Box Fill")
periodBoxBorder  = input.color(color.new(color.gray, 60), "Period Box Border")
profitBoxBg      = input.color(color.new(color.green, 75), "Profit Box Fill")
ddBoxBg          = input.color(color.new(color.red, 75), "Drawdown Box Fill")
tableBgColor     = input.color(color.new(color.black, 15), "Table Background")
tableTextColor   = input.color(color.white, "Table Text")
tableBorderColor = input.color(color.new(color.white, 45), "Table Border")

// Fresh Start re-entry: after TP, anchor resets and starts tracking from next bar

// ── Pair helpers ────────────────────────────────────────────────────────────
canonicalizePair(_s) =>
    string x = str.upper(_s)
    x := str.replace_all(x, "OANDA:", "")
    x := str.replace_all(x, "FX:", "")
    x := str.replace_all(x, "FOREXCOM:", "")
    x := str.replace_all(x, "PEPPERSTONE:", "")
    x := str.replace_all(x, "EIGHTCAP:", "")
    x := str.replace_all(x, "CAPITALCOM:", "")
    x := str.replace_all(x, "BLACKBULL:", "")
    x := str.replace_all(x, "ICMARKETS:", "")
    x := str.replace_all(x, "INDEX:", "")
    x := str.replace_all(x, "/", "")
    x := str.replace_all(x, ".", "")
    x := str.replace_all(x, "_", "")
    x := str.replace_all(x, "-", "")
    if x == "NIKKEI" or x == "NIK225" or x == "JP225" or x == "NIKKEI225" or x == "JAPAN225" or x == "JP225USD" or x == "JPN225USD" or x == "NIKKEIUSD"
        x := "JPN225"
    if x == "SP500" or x == "US500" or x == "SPXUSD" or x == "SPX500USD" or x == "US500USD"
        x := "SPX500"
    if x == "NAS100" or x == "US100" or x == "NDXUSD" or x == "NDX100USD" or x == "NAS100USD" or x == "US100USD"
        x := "NDX100"
    if x == "USOIL" or x == "USOUSD" or x == "XTIUSD"
        x := "WTIUSD"
    if x == "BTCUSDT"
        x := "BTCUSD"
    if x == "ETHUSDT"
        x := "ETHUSD"
    x

normalizePairList(_raw) =>
    string cleaned = str.upper(_raw)
    cleaned := str.replace_all(cleaned, " ", "")
    cleaned := str.replace_all(cleaned, "\r", ",")
    cleaned := str.replace_all(cleaned, "\n", ",")
    cleaned := str.replace_all(cleaned, ";", ",")
    cleaned := str.replace_all(cleaned, "/", "")
    cleaned := str.replace_all(cleaned, ".", "")
    cleaned := str.replace_all(cleaned, "_", "")
    cleaned := str.replace_all(cleaned, "-", "")
    cleaned := str.replace_all(cleaned, "NIKKEIUSD", "JPN225")
    cleaned := str.replace_all(cleaned, "NIKKEI225", "JPN225")
    cleaned := str.replace_all(cleaned, "NIK225", "JPN225")
    cleaned := str.replace_all(cleaned, "JP225USD", "JPN225")
    cleaned := str.replace_all(cleaned, "JPN225USD", "JPN225")
    cleaned := str.replace_all(cleaned, "JP225", "JPN225")
    cleaned := str.replace_all(cleaned, "JAPAN225", "JPN225")
    cleaned := str.replace_all(cleaned, "SPX500USD", "SPX500")
    cleaned := str.replace_all(cleaned, "US500USD", "SPX500")
    cleaned := str.replace_all(cleaned, "SP500", "SPX500")
    cleaned := str.replace_all(cleaned, "US500", "SPX500")
    cleaned := str.replace_all(cleaned, "SPXUSD", "SPX500")
    cleaned := str.replace_all(cleaned, "NAS100USD", "NDX100")
    cleaned := str.replace_all(cleaned, "NDX100USD", "NDX100")
    cleaned := str.replace_all(cleaned, "US100USD", "NDX100")
    cleaned := str.replace_all(cleaned, "NAS100", "NDX100")
    cleaned := str.replace_all(cleaned, "US100", "NDX100")
    cleaned := str.replace_all(cleaned, "NDXUSD", "NDX100")
    cleaned := str.replace_all(cleaned, "USOIL", "WTIUSD")
    cleaned := str.replace_all(cleaned, "USOUSD", "WTIUSD")
    cleaned := str.replace_all(cleaned, "XTIUSD", "WTIUSD")
    cleaned := str.replace_all(cleaned, "BTCUSDT", "BTCUSD")
    cleaned := str.replace_all(cleaned, "ETHUSDT", "ETHUSD")
    cleaned

listContainsPair(_list, _pair) =>
    string wrappedList = "," + normalizePairList(_list) + ","
    string cleanPair = canonicalizePair(_pair)
    string wrappedPair = "," + cleanPair + ","
    str.length(cleanPair) > 0 and str.contains(wrappedList, wrappedPair)

getManualBias(_pair) =>
    bool inLong = listContainsPair(longPairs, _pair)
    bool inShort = listContainsPair(shortPairs, _pair)
    string result = "NEUTRAL"
    if inLong and not inShort
        result := "LONG"
    else if inShort and not inLong
        result := "SHORT"
    result

// ── ADR calculation ─────────────────────────────────────────────────────────
calcAdrStats() =>
    float rangeSum = 0.0
    float validCnt = 0.0
    for i = 1 to adrLookback
        bool ok = not na(high[i]) and not na(low[i]) and high[i] > 0 and low[i] > 0
        if ok
            rangeSum += (high[i] - low[i])
            validCnt += 1
    [rangeSum, validCnt]

[dailyAdrSum, dailyAdrCount] = request.security(syminfo.tickerid, "D", calcAdrStats(), lookahead=barmerge.lookahead_off)
float currentAdrDistance = dailyAdrCount >= adrMinDays ? dailyAdrSum / dailyAdrCount : na

// ── Weekly state ────────────────────────────────────────────────────────────
bool isNewWeek = ta.change(time("W")) != 0
// When currentOnly: only show visuals for bars in the current calendar week
// timenow - time("W") < 7 days means the bar is in the week containing "now"
bool showVisuals = not currentOnly or (timenow - time("W") < 7 * 24 * 60 * 60 * 1000)

var float weekAdr = na
var int barsInWeek = 0

// weekHigh/weekLow: true week range (for period box, always cumulative)
var float weekHigh = na
var float weekLow  = na

// anchorHigh/anchorLow: entry anchor (resets in Fresh mode after TP)
var float anchorHigh = na
var float anchorLow  = na
var int barsInAnchor = 0

if barstate.isfirst or isNewWeek
    weekAdr    := currentAdrDistance
    weekHigh   := high
    weekLow    := low
    anchorHigh := high
    anchorLow  := low
    barsInWeek   := 0
    barsInAnchor := 0
else
    barsInWeek += 1
    barsInAnchor += 1
    weekHigh   := math.max(weekHigh, high)
    weekLow    := math.min(weekLow, low)

// Snapshot anchor BEFORE updating with current bar — prevents circular dependency
// where current bar's low/high influences anchor AND triggers on the same bar
float prevAnchorHigh = anchorHigh
float prevAnchorLow  = anchorLow

// Now update anchor with current bar
if not (barstate.isfirst or isNewWeek)
    anchorHigh := math.max(anchorHigh, high)
    anchorLow  := math.min(anchorLow, low)

// ── Bias ────────────────────────────────────────────────────────────────────
string tickerUpper = canonicalizePair(syminfo.ticker)
string resolvedBias = getManualBias(tickerUpper)

string btcBias = getManualBias("BTCUSD")
string ethBias = getManualBias("ETHUSD")
string cryptoRegime = "NEUTRAL"
if btcBias == "LONG" and ethBias == "LONG"
    cryptoRegime := "LONG"
else if btcBias == "SHORT" and ethBias == "SHORT"
    cryptoRegime := "SHORT"

bool isCrypto = syminfo.type == "crypto"
bool isMajorCrypto = tickerUpper == "BTCUSD" or tickerUpper == "ETHUSD"
if isCrypto and not isMajorCrypto
    resolvedBias := cryptoRegime

bool showLong  = resolvedBias == "LONG"
bool showShort = resolvedBias == "SHORT"

// ── Dynamic entry / TP levels (from PREVIOUS bar's anchor) ──────────────────
// Using prevAnchor ensures entry level isn't influenced by current bar's own high/low
// This makes the indicator timeframe-independent
bool adrReady = not na(weekAdr) and not na(prevAnchorHigh) and not na(prevAnchorLow) and barsInAnchor >= 1

float longEntry  = adrReady ? prevAnchorHigh - (weekAdr * entryMultiple) : na
float longTp     = adrReady ? longEntry + (weekAdr * tpMultiple)         : na
float shortEntry = adrReady ? prevAnchorLow  + (weekAdr * entryMultiple) : na
float shortTp    = adrReady ? shortEntry - (weekAdr * tpMultiple)        : na

// ── Pip calculations ────────────────────────────────────────────────────────
bool isJpyPair = str.contains(tickerUpper, "JPY")
float pipSize = syminfo.type == "forex" ? (isJpyPair ? 0.01 : 0.0001) : syminfo.mintick
float adrPips     = adrReady and pipSize > 0 ? weekAdr / pipSize : na
float longTpPips  = adrReady and pipSize > 0 ? math.abs(longTp - longEntry) / pipSize : na
float shortTpPips = adrReady and pipSize > 0 ? math.abs(shortEntry - shortTp) / pipSize : na

// ── Trade state machine ─────────────────────────────────────────────────────
// States: 0 = waiting, 1 = triggered (in trade)
// Fresh: anchor resets after TP, starts tracking from next bar
var int longState  = 0
var int shortState = 0
var float frozenLongEntry  = na
var float frozenLongTp     = na
var float frozenShortEntry = na
var float frozenShortTp    = na

// Weekly trade counters
var int weekTrades = 0
var int weekTpHits = 0

if barstate.isfirst or isNewWeek
    longState  := 0
    shortState := 0
    frozenLongEntry  := na
    frozenLongTp     := na
    frozenShortEntry := na
    frozenShortTp    := na
    weekTrades := 0
    weekTpHits := 0

bool longTpHit = false
bool shortTpHit = false

if longState == 1
    if not na(frozenLongTp) and high >= frozenLongTp
        longTpHit := true
        longState := 0
        frozenLongEntry := na
        frozenLongTp    := na
        anchorHigh   := na
        barsInAnchor := -1
        weekTpHits += 1
else if longState == 0 and adrReady and showLong and not na(longEntry) and low <= longEntry
    longState := 1
    frozenLongEntry := longEntry
    frozenLongTp    := longTp
    weekTrades += 1

if shortState == 1
    if not na(frozenShortTp) and low <= frozenShortTp
        shortTpHit := true
        shortState := 0
        frozenShortEntry := na
        frozenShortTp    := na
        anchorLow    := na
        barsInAnchor := -1
        weekTpHits += 1
else if shortState == 0 and adrReady and showShort and not na(shortEntry) and high >= shortEntry
    shortState := 1
    frozenShortEntry := shortEntry
    frozenShortTp    := shortTp
    weekTrades += 1

// Seed anchor from current bar after reset
if na(anchorHigh)
    anchorHigh   := high
    anchorLow    := low
    barsInAnchor := 0
if na(anchorLow)
    anchorLow    := low
    barsInAnchor := 0

// ── 5M state override (timeframe-independent accuracy) ──────────────────────
// request.security("5") re-evaluates the entire script at 5M and returns the
// final state from the last completed 5M bar. This gives 5M-accurate trade
// counts and levels regardless of chart TF. Boxes use chart-bar positions.
[ls5, ss5, wt5, wth5, fle5, flt5, fse5, fst5] = request.security(syminfo.tickerid, "5", [longState, shortState, weekTrades, weekTpHits, frozenLongEntry, frozenLongTp, frozenShortEntry, frozenShortTp], lookahead=barmerge.lookahead_off)
[le5, lt5, se5, st5, wa5, ar5] = request.security(syminfo.tickerid, "5", [longEntry, longTp, shortEntry, shortTp, weekAdr, adrReady ? 1.0 : 0.0], lookahead=barmerge.lookahead_off)

// Override chart-level state with 5M values
longState       := int(nz(ls5))
shortState      := int(nz(ss5))
weekTrades      := int(nz(wt5))
weekTpHits      := int(nz(wth5))
frozenLongEntry := fle5
frozenLongTp    := flt5
frozenShortEntry := fse5
frozenShortTp   := fst5
longEntry       := le5
longTp          := lt5
shortEntry      := se5
shortTp         := st5
weekAdr         := wa5
adrReady        := nz(ar5) > 0.5

// Recompute pips from 5M-overridden values
adrPips     := adrReady and pipSize > 0 ? weekAdr / pipSize : na
longTpPips  := adrReady and pipSize > 0 ? math.abs(longTp - longEntry) / pipSize : na
shortTpPips := adrReady and pipSize > 0 ? math.abs(shortEntry - shortTp) / pipSize : na

// Detect state transitions from 5M state (for box drawing at chart-bar positions)
bool longTriggeredNow  = longState == 1 and nz(longState[1]) != 1
bool shortTriggeredNow = shortState == 1 and nz(shortState[1]) != 1
bool longTpHit2  = longState == 0 and nz(longState[1]) == 1
bool shortTpHit2 = shortState == 0 and nz(shortState[1]) == 1
longTpHit  := longTpHit or longTpHit2
shortTpHit := shortTpHit or shortTpHit2

// ── Trade log + max drawdown tracking ────────────────────────────────────────
var string[] tradeEntries = array.new_string(0)
var int loggedTrades = 0
var int loggedTpHits = 0
var float currentTradeDDPips = 0.0
var float weekMaxDDPips = 0.0

if barstate.isfirst or isNewWeek
    array.clear(tradeEntries)
    loggedTrades     := 0
    loggedTpHits     := 0
    currentTradeDDPips := 0.0
    weekMaxDDPips    := 0.0

// Track drawdown while in trade (chart-bar low/high captures full range)
if longState == 1 and not na(frozenLongEntry) and pipSize > 0
    float dd = (frozenLongEntry - low) / pipSize
    if dd > 0
        currentTradeDDPips := math.max(currentTradeDDPips, dd)

if shortState == 1 and not na(frozenShortEntry) and pipSize > 0
    float dd = (high - frozenShortEntry) / pipSize
    if dd > 0
        currentTradeDDPips := math.max(currentTradeDDPips, dd)

// When TP hits: record max DD then reset for next trade
if longTpHit2 or shortTpHit2
    weekMaxDDPips      := math.max(weekMaxDDPips, currentTradeDDPips)
    currentTradeDDPips := 0.0

// Log new trades from 5M state
if weekTrades > loggedTrades
    string dir  = longState == 1 ? "LONG" : shortState == 1 ? "SHORT" : "?"
    string ep   = longState == 1 ? str.tostring(frozenLongEntry, format.mintick) : str.tostring(frozenShortEntry, format.mintick)
    string tp   = longState == 1 ? str.tostring(frozenLongTp, format.mintick) : str.tostring(frozenShortTp, format.mintick)
    array.push(tradeEntries, "#" + str.tostring(weekTrades) + " " + dir + " | " + ep + " → " + tp + " | ACTIVE")
    loggedTrades := weekTrades

// Mark TP hits in the log
if weekTpHits > loggedTpHits and array.size(tradeEntries) > 0
    int lastIdx = array.size(tradeEntries) - 1
    string lastEntry = array.get(tradeEntries, lastIdx)
    array.set(tradeEntries, lastIdx, str.replace_all(lastEntry, "| ACTIVE", "| TP HIT"))
    loggedTpHits := weekTpHits

// ── Trade log table (bottom-left, toggleable) ───────────────────────────────
var table logTable = table.new(position.bottom_left, 2, 14, border_width=1, border_color=tableBorderColor, bgcolor=tableBgColor)

if showTradeLog and barstate.islast
    // Header
    table.cell(logTable, 0, 0, "TRADE LOG", text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(logTable, 1, 0, syminfo.ticker + " | " + resolvedBias, text_color=tableTextColor, bgcolor=color.new(color.white, 85))

    // Summary
    table.cell(logTable, 0, 1, "ADR", text_color=tableTextColor)
    table.cell(logTable, 1, 1, str.tostring(weekAdr, format.mintick) + " (" + str.tostring(adrPips, "#.#") + " pips)", text_color=tableTextColor)

    table.cell(logTable, 0, 2, "Trades / TP", text_color=tableTextColor)
    table.cell(logTable, 1, 2, str.tostring(weekTrades) + " trades / " + str.tostring(weekTpHits) + " TP", text_color=weekTpHits > 0 ? color.lime : tableTextColor)

    // Max DD (worst of all closed trades, or current if still active)
    float displayDD = math.max(weekMaxDDPips, currentTradeDDPips)
    table.cell(logTable, 0, 3, "Max DD", text_color=tableTextColor)
    table.cell(logTable, 1, 3, displayDD > 0 ? str.tostring(displayDD, "#.#") + " pips" : "-", text_color=displayDD > 0 ? color.red : tableTextColor)

    // Individual trades
    int numTrades = math.min(array.size(tradeEntries), 10)
    for i = 0 to numTrades - 1
        table.cell(logTable, 0, 4 + i, "", text_color=tableTextColor)
        table.cell(logTable, 1, 4 + i, array.get(tradeEntries, i), text_color=tableTextColor)

    // Clear remaining rows
    for i = numTrades to 9
        table.cell(logTable, 0, 4 + i, "", text_color=tableTextColor)
        table.cell(logTable, 1, 4 + i, "", text_color=tableTextColor)

if not showTradeLog and barstate.islast
    table.clear(logTable, 0, 0, 1, 13)

// ── Period box (always uses true weekHigh/weekLow) ──────────────────────────
var box periodBox = na
var float periodHigh = na
var float periodLow = na

if (barstate.isfirst or isNewWeek) and showBoxes and showVisuals
    periodHigh := high
    periodLow  := low
    periodBox  := box.new(bar_index, high, bar_index, low, bgcolor=periodBoxBg, border_color=periodBoxBorder, border_width=1, border_style=line.style_dotted)

if not na(periodBox) and showBoxes and showVisuals
    periodHigh := math.max(periodHigh, high)
    periodLow  := math.min(periodLow, low)
    box.set_top(periodBox, periodHigh)
    box.set_bottom(periodBox, periodLow)
    box.set_right(periodBox, bar_index)

// ── Trade boxes (profit + drawdown — detach on TP for re-entry) ─────────────
var box longProfBox = na
var box longDDBox = na
var float longDDLow = na
var box shortProfBox = na
var box shortDDBox = na
var float shortDDHigh = na

if barstate.isfirst or isNewWeek
    longProfBox  := na
    longDDBox    := na
    longDDLow    := na
    shortProfBox := na
    shortDDBox   := na
    shortDDHigh  := na

if longTpHit
    longProfBox := na
    longDDBox   := na
    longDDLow   := na

if shortTpHit
    shortProfBox := na
    shortDDBox   := na
    shortDDHigh  := na

if longTriggeredNow and showBoxes and showVisuals and not na(frozenLongEntry) and not na(frozenLongTp)
    longProfBox := box.new(bar_index, frozenLongTp, bar_index, frozenLongEntry, bgcolor=profitBoxBg, border_color=color.lime, border_width=2)
    label.new(bar_index, frozenLongTp, "L#" + str.tostring(weekTrades), style=label.style_label_down, color=color.new(color.lime, 60), textcolor=color.white, size=size.tiny)
    longDDBox   := na
    longDDLow   := low

if longState == 1 and not na(longProfBox)
    box.set_right(longProfBox, bar_index)

if longState == 1
    longDDLow := na(longDDLow) ? low : math.min(longDDLow, low)
    if not na(frozenLongEntry) and not na(longDDLow) and longDDLow < frozenLongEntry
        if na(longDDBox) and showBoxes and showVisuals
            longDDBox := box.new(bar_index, frozenLongEntry, bar_index, longDDLow, bgcolor=ddBoxBg, border_color=color.red, border_width=1)
        else if not na(longDDBox)
            box.set_right(longDDBox, bar_index)
            box.set_bottom(longDDBox, longDDLow)

if shortTriggeredNow and showBoxes and showVisuals and not na(frozenShortEntry) and not na(frozenShortTp)
    shortProfBox := box.new(bar_index, frozenShortEntry, bar_index, frozenShortTp, bgcolor=profitBoxBg, border_color=color.lime, border_width=2)
    label.new(bar_index, frozenShortTp, "S#" + str.tostring(weekTrades), style=label.style_label_up, color=color.new(color.red, 60), textcolor=color.white, size=size.tiny)
    shortDDBox   := na
    shortDDHigh  := high

if shortState == 1 and not na(shortProfBox)
    box.set_right(shortProfBox, bar_index)

if shortState == 1
    shortDDHigh := na(shortDDHigh) ? high : math.max(shortDDHigh, high)
    if not na(frozenShortEntry) and not na(shortDDHigh) and shortDDHigh > frozenShortEntry
        if na(shortDDBox) and showBoxes and showVisuals
            shortDDBox := box.new(bar_index, shortDDHigh, bar_index, frozenShortEntry, bgcolor=ddBoxBg, border_color=color.red, border_width=1)
        else if not na(shortDDBox)
            box.set_right(shortDDBox, bar_index)
            box.set_top(shortDDBox, shortDDHigh)

// ── Info table ──────────────────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 9, border_width=1, border_color=tableBorderColor, bgcolor=tableBgColor)

if showTable and barstate.islast
    color biasColor = resolvedBias == "LONG" ? color.lime : resolvedBias == "SHORT" ? color.red : tableTextColor
    string longStateLabel  = longState == 0 ? (longTpHit ? "TP Hit" : "Waiting") : "TRIGGERED"
    string shortStateLabel = shortState == 0 ? (shortTpHit ? "TP Hit" : "Waiting") : "TRIGGERED"

    string longCellText = "-"
    if adrReady and not na(longEntry) and not na(longTp)
        longCellText := str.tostring(longEntry, format.mintick) + " / " + str.tostring(longTp, format.mintick) + "\nTP: " + str.tostring(longTpPips, "#.#") + " pips"

    string shortCellText = "-"
    if adrReady and not na(shortEntry) and not na(shortTp)
        shortCellText := str.tostring(shortEntry, format.mintick) + " / " + str.tostring(shortTp, format.mintick) + "\nTP: " + str.tostring(shortTpPips, "#.#") + " pips"

    string statusText = ""
    if showLong
        statusText += "L: " + longStateLabel
    if showLong and showShort
        statusText += " | "
    if showShort
        statusText += "S: " + shortStateLabel

    color activeStatusColor = longState == 1 or shortState == 1 ? color.yellow : tableTextColor
    color cryptoColor = cryptoRegime == "LONG" ? color.lime : cryptoRegime == "SHORT" ? color.red : tableTextColor

    table.cell(infoTable, 0, 0, "Limni ADR", text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(infoTable, 1, 0, syminfo.ticker, text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(infoTable, 0, 1, "Anchor", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 1, "5M Anchored", text_color=color.new(color.yellow, 0), bgcolor=tableBgColor)
    table.cell(infoTable, 0, 2, "Bias", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 2, resolvedBias, text_color=biasColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 3, "ADR Pips", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 3, adrReady ? str.tostring(adrPips, "#.#") + " pips" : "-", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 4, "Long Entry / TP", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 4, longCellText, text_color=color.lime, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 5, "Short Entry / TP", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 5, shortCellText, text_color=color.red, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 6, "Trade Status", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 6, statusText, text_color=activeStatusColor, bgcolor=tableBgColor)
    string tradesText = str.tostring(weekTrades) + " trades / " + str.tostring(weekTpHits) + " TP"
    color tradesColor = weekTpHits > 0 ? color.lime : tableTextColor
    table.cell(infoTable, 0, 7, "This Week", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 7, tradesText, text_color=tradesColor, bgcolor=tableBgColor)
    if isCrypto
        table.cell(infoTable, 0, 8, "Crypto Regime", text_color=tableTextColor, bgcolor=tableBgColor)
        table.cell(infoTable, 1, 8, cryptoRegime, text_color=cryptoColor, bgcolor=tableBgColor)
    else
        table.cell(infoTable, 0, 8, "", text_color=tableTextColor, bgcolor=tableBgColor)
        table.cell(infoTable, 1, 8, "", text_color=tableTextColor, bgcolor=tableBgColor)

if not showTable and barstate.islast
    table.clear(infoTable, 0, 0, 1, 8)
