//@version=6
indicator("Limni ADR Levels", shorttitle="Limni ADR", overlay=true, format=format.price, max_boxes_count=500, max_lines_count=500, max_labels_count=200)

// ── Inputs ──────────────────────────────────────────────────────────────────
anchorMode    = input.string("Weekly", "ADR Anchor Mode", options=["Weekly", "Daily", "Freedom"], tooltip="Weekly = week open anchor (1 trade/week). Daily = day open anchor (1 trade/day). Freedom = running weekly extreme, resets after each TP hit (multiple trades/week).")
anchorLogic   = input.string("Extreme", "ADR Anchor Logic", options=["Extreme", "Static"], tooltip="Extreme = anchor to running period high/low (dynamic, more fills). Static = anchor to period open price (fixed). Freedom mode always uses Extreme regardless.")
adrLookback   = input.int(10, "ADR Lookback (days)", minval=1, maxval=50)
adrMinDays    = input.int(5, "ADR Min Required Days", minval=1, maxval=50)
entryMultiple = input.float(1.0, "ADR Entry Multiple", minval=0.1, step=0.05)
tpMultiple    = input.float(0.25, "TP ADR Multiple", minval=0.05, step=0.05)
longPairs     = input.text_area("", "LONG Pairs (comma/newline)", tooltip="Bullish pairs for the week. Crypto: BTCUSD+ETHUSD set regime for alts.")
shortPairs    = input.text_area("", "SHORT Pairs (comma/newline)", tooltip="Bearish pairs for the week.")
showTable     = input.bool(true, "Show Info Table")
showBoxes     = input.bool(true, "Show Trade Boxes", tooltip="Draw period boxes, entry zones, and trade boxes.")

// Color inputs
periodBoxBg      = input.color(color.new(#2a2e39, 70), "Period Box Fill", tooltip="Faint background box for the period playground.")
periodBoxBorder  = input.color(color.new(color.gray, 60), "Period Box Border")
entryZoneBg      = input.color(color.new(color.green, 80), "Entry Zone Fill (pre-drawn target)")
longEntryBorder  = input.color(color.new(color.lime, 30), "Long Entry Zone Border")
shortEntryBorder = input.color(color.new(color.red, 30), "Short Entry Zone Border")
profitBoxBg      = input.color(color.new(color.green, 75), "Profit Box Fill")
ddBoxBg          = input.color(color.new(color.red, 75), "Drawdown Box Fill")
tableBgColor     = input.color(color.new(color.black, 15), "Table Background")
tableTextColor   = input.color(color.white, "Table Text")
tableBorderColor = input.color(color.new(color.white, 45), "Table Border")

// ── Pair List Helpers ───────────────────────────────────────────────────────
normalizePairList(_raw) =>
    string cleaned = str.upper(_raw)
    cleaned := str.replace_all(cleaned, " ", "")
    cleaned := str.replace_all(cleaned, "\r", ",")
    cleaned := str.replace_all(cleaned, "\n", ",")
    cleaned := str.replace_all(cleaned, ";", ",")
    cleaned := str.replace_all(cleaned, "/", "")
    cleaned := str.replace_all(cleaned, ".", "")
    cleaned

listContainsPair(_list, _pair) =>
    string wrappedList = "," + normalizePairList(_list) + ","
    string cleanPair   = str.replace_all(str.replace_all(str.upper(_pair), "/", ""), ".", "")
    string wrappedPair = "," + cleanPair + ","
    str.length(cleanPair) > 0 and str.contains(wrappedList, wrappedPair)

getManualBias(_pair) =>
    bool inLong  = listContainsPair(longPairs, _pair)
    bool inShort = listContainsPair(shortPairs, _pair)
    string result = "NEUTRAL"
    if inLong and not inShort
        result := "LONG"
    else if inShort and not inLong
        result := "SHORT"
    result

// ── ADR Calculation ─────────────────────────────────────────────────────────
calcAdrStats() =>
    float rangeSum   = 0.0
    float validCount = 0.0
    for i = 1 to adrLookback
        bool validBar = open[i] > 0 and not na(high[i]) and not na(low[i])
        if validBar
            rangeSum   += ((high[i] - low[i]) / open[i]) * 100
            validCount += 1
    [rangeSum, validCount]

[dailyAdrSum, dailyAdrCount] = request.security(syminfo.tickerid, "D", calcAdrStats(), lookahead=barmerge.lookahead_off)
currentAdrPct = dailyAdrCount >= adrMinDays ? dailyAdrSum / dailyAdrCount : na

// ── Anchor Data ─────────────────────────────────────────────────────────────
// Weekly
weeklyOpenSeries = request.security(syminfo.tickerid, "W", open, lookahead=barmerge.lookahead_on)
isNewWeek = ta.change(time("W")) != 0

var float weekOpenPrice = na
var float weekAdrPct    = na

if barstate.isfirst or isNewWeek
    weekOpenPrice := weeklyOpenSeries
    weekAdrPct    := currentAdrPct

// Daily
dailyOpenSeries = request.security(syminfo.tickerid, "D", open, lookahead=barmerge.lookahead_on)
isNewDay = ta.change(time("D")) != 0

var float dayOpenPrice   = na
var float dayAdrPct      = na
var float dayRunningHigh = na
var float dayRunningLow  = na

if barstate.isfirst or isNewDay
    dayOpenPrice   := dailyOpenSeries
    dayAdrPct      := currentAdrPct
    dayRunningHigh := high
    dayRunningLow  := low
else
    dayRunningHigh := na(dayRunningHigh) ? high : math.max(dayRunningHigh, high)
    dayRunningLow  := na(dayRunningLow)  ? low  : math.min(dayRunningLow, low)

// Freedom — running weekly extremes (manually tracked, no lookahead future leak)
var float weekRunningHigh   = na
var float weekRunningLow    = na
var float weekFreedomAdrPct = na

if barstate.isfirst or isNewWeek
    weekRunningHigh   := high
    weekRunningLow    := low
    weekFreedomAdrPct := currentAdrPct
else
    weekRunningHigh := na(weekRunningHigh) ? high : math.max(weekRunningHigh, high)
    weekRunningLow  := na(weekRunningLow)  ? low  : math.min(weekRunningLow, low)

// ── Anchor Selection ────────────────────────────────────────────────────────
bool useDaily    = anchorMode == "Daily"
bool useFreedom  = anchorMode == "Freedom"
bool useExtreme  = anchorLogic == "Extreme" or useFreedom  // Freedom always uses extreme

anchorOpenPrice   = useFreedom ? na : useDaily ? dayOpenPrice : weekOpenPrice
anchorAdrPct      = useFreedom ? weekFreedomAdrPct : useDaily ? dayAdrPct : weekAdrPct
periodRunningHigh = useDaily ? dayRunningHigh : weekRunningHigh
periodRunningLow  = useDaily ? dayRunningLow  : weekRunningLow

adrReady = useExtreme ? (not na(periodRunningHigh) and not na(periodRunningLow) and not na(anchorAdrPct)) : (not na(anchorOpenPrice) and not na(anchorAdrPct))

// ── Bias Resolution ─────────────────────────────────────────────────────────
tickerUpper  = str.replace_all(str.replace_all(str.upper(syminfo.ticker), "/", ""), ".", "")
manualBias   = getManualBias(tickerUpper)
btcBias      = getManualBias("BTCUSD")
ethBias      = getManualBias("ETHUSD")

cryptoRegime = "NEUTRAL"
if btcBias == "LONG" and ethBias == "LONG"
    cryptoRegime := "LONG"
else if btcBias == "SHORT" and ethBias == "SHORT"
    cryptoRegime := "SHORT"

isCrypto      = syminfo.type == "crypto"
isMajorCrypto = tickerUpper == "BTCUSD" or tickerUpper == "ETHUSD"
resolvedBias  = manualBias
if isCrypto and not isMajorCrypto
    resolvedBias := cryptoRegime

showLong  = resolvedBias == "LONG"
showShort = resolvedBias == "SHORT"

// ── Level Calculation ───────────────────────────────────────────────────────
// Extreme: LONG = runningHigh * (1 - ADR%) → mean reversion long after downside extension from high
//          SHORT = runningLow * (1 + ADR%) → mean reversion short after upside extension from low
// Static:  LONG = open * (1 - ADR%) → dip below open
//          SHORT = open * (1 + ADR%) → bounce above open
// Freedom: always extreme with weekly anchors.
staticLongEntry  = anchorOpenPrice * (1 - anchorAdrPct * entryMultiple / 100)
staticShortEntry = anchorOpenPrice * (1 + anchorAdrPct * entryMultiple / 100)

extremeLongEntry  = periodRunningHigh * (1 - anchorAdrPct * entryMultiple / 100)
extremeShortEntry = periodRunningLow  * (1 + anchorAdrPct * entryMultiple / 100)

longEntryPrice  = adrReady ? (useExtreme ? extremeLongEntry  : staticLongEntry)  : na
shortEntryPrice = adrReady ? (useExtreme ? extremeShortEntry : staticShortEntry) : na

longTpPrice  = adrReady ? longEntryPrice  * (1 + anchorAdrPct * tpMultiple / 100) : na
shortTpPrice = adrReady ? shortEntryPrice * (1 - anchorAdrPct * tpMultiple / 100) : na

longAdrDistance  = adrReady ? math.abs((useExtreme ? periodRunningHigh : anchorOpenPrice) - longEntryPrice)   : na
shortAdrDistance = adrReady ? math.abs(shortEntryPrice - (useExtreme ? periodRunningLow : anchorOpenPrice))    : na

pipSize     = syminfo.type == "forex" ? (syminfo.currency == "JPY" ? 0.01 : 0.0001) : syminfo.mintick
adrPips     = adrReady and pipSize > 0 ? ((showLong and not na(longAdrDistance) ? longAdrDistance : shortAdrDistance) / pipSize) : na
longTpPips  = adrReady and pipSize > 0 ? math.abs(longTpPrice  - longEntryPrice)  / pipSize : na
shortTpPips = adrReady and pipSize > 0 ? math.abs(shortEntryPrice - shortTpPrice) / pipSize : na

// ── Period Detection ────────────────────────────────────────────────────────
isNewPeriod = useFreedom ? isNewWeek : (useDaily ? isNewDay : isNewWeek)

var int currentPeriodStart = na
if isNewPeriod
    currentPeriodStart := time
showCurrentPeriod = not na(currentPeriodStart) and time >= currentPeriodStart

// ── Period Background Box ───────────────────────────────────────────────────
var box periodBox        = na
var float periodHigh     = na
var float periodLow      = na
var int periodBarStart   = na

if isNewPeriod and showBoxes
    periodBox := na
    periodHigh     := high
    periodLow      := low
    periodBarStart := bar_index
    periodBox := box.new(bar_index, high, bar_index, low, bgcolor=periodBoxBg, border_color=periodBoxBorder, border_width=1, border_style=line.style_dotted)

if not na(periodBox) and showBoxes
    periodHigh := math.max(periodHigh, high)
    periodLow  := math.min(periodLow, low)
    box.set_top(periodBox, periodHigh)
    box.set_bottom(periodBox, periodLow)
    box.set_right(periodBox, bar_index)

// ── Entry Zone Boxes (pre-drawn target zones) ───────────────────────────────
var box longEntryZone  = na
var box shortEntryZone = na

if isNewPeriod and not useExtreme and showBoxes
    longEntryZone  := na
    shortEntryZone := na
    if adrReady and showLong and not na(longEntryPrice) and not na(longTpPrice)
        longEntryZone := box.new(bar_index, longTpPrice, bar_index, longEntryPrice, bgcolor=entryZoneBg, border_color=longEntryBorder, border_width=1)
    if adrReady and showShort and not na(shortEntryPrice) and not na(shortTpPrice)
        shortEntryZone := box.new(bar_index, shortEntryPrice, bar_index, shortTpPrice, bgcolor=entryZoneBg, border_color=shortEntryBorder, border_width=1)

if not na(longEntryZone) and showBoxes
    box.set_right(longEntryZone, bar_index)
if not na(shortEntryZone) and showBoxes
    box.set_right(shortEntryZone, bar_index)

// ── Trade State Machine ─────────────────────────────────────────────────────
var int   longState     = 0
var int   longEntryBar  = 0
var float longEntry     = na
var float longTp        = na
var float longDDLow     = na
var box   longProfBox   = na
var box   longDDBox     = na

var int   shortState    = 0
var int   shortEntryBar = 0
var float shortEntry    = na
var float shortTp       = na
var float shortDDHigh   = na
var box   shortProfBox  = na
var box   shortDDBox    = na

// ── Period Reset ────────────────────────────────────────────────────────────
if isNewPeriod
    longProfBox  := na
    longDDBox    := na
    shortProfBox := na
    shortDDBox   := na

    longState    := 0
    shortState   := 0

    longEntry    := na
    longTp       := na
    longDDLow    := na

    shortEntry   := na
    shortTp      := na
    shortDDHigh  := na

// First-bar guard: prevent extreme triggers on period start bar
extremeEntryEligible = not useExtreme or (not na(periodBarStart) and bar_index > periodBarStart)

// ── LONG State Machine ─────────────────────────────────────────────────────
if longState == 1
    if low < longDDLow
        longDDLow := low
    if not na(longProfBox)
        box.set_right(longProfBox, bar_index)
    if longDDLow < longEntry
        if na(longDDBox) and showBoxes
            longDDBox := box.new(longEntryBar, longEntry, bar_index, longDDLow, bgcolor=ddBoxBg, border_color=color.red, border_width=1)
        else if not na(longDDBox)
            box.set_right(longDDBox, bar_index)
            box.set_bottom(longDDBox, longDDLow)
    if high >= longTp
        longState   := useFreedom ? 0 : 2
        longProfBox := na
        longDDBox   := na

else if longState == 0 and adrReady and showLong and showCurrentPeriod and extremeEntryEligible
    if not na(longEntryPrice) and low <= longEntryPrice
        longState    := 1
        longEntryBar := bar_index
        longEntry    := longEntryPrice
        longTp       := longTpPrice
        longDDLow    := low
        if showBoxes
            longProfBox := box.new(bar_index, longTp, bar_index, longEntry, bgcolor=profitBoxBg, border_color=color.lime, border_width=2)

// ── SHORT State Machine ────────────────────────────────────────────────────
if shortState == 1
    if high > shortDDHigh
        shortDDHigh := high
    if not na(shortProfBox)
        box.set_right(shortProfBox, bar_index)
    if shortDDHigh > shortEntry
        if na(shortDDBox) and showBoxes
            shortDDBox := box.new(shortEntryBar, shortDDHigh, bar_index, shortEntry, bgcolor=ddBoxBg, border_color=color.red, border_width=1)
        else if not na(shortDDBox)
            box.set_right(shortDDBox, bar_index)
            box.set_top(shortDDBox, shortDDHigh)
    if low <= shortTp
        shortState   := useFreedom ? 0 : 2
        shortProfBox := na
        shortDDBox   := na

else if shortState == 0 and adrReady and showShort and showCurrentPeriod and extremeEntryEligible
    if not na(shortEntryPrice) and high >= shortEntryPrice
        shortState    := 1
        shortEntryBar := bar_index
        shortEntry    := shortEntryPrice
        shortTp       := shortTpPrice
        shortDDHigh   := high
        if showBoxes
            shortProfBox := box.new(bar_index, shortEntry, bar_index, shortTp, bgcolor=profitBoxBg, border_color=color.lime, border_width=2)

// ── Info Table ──────────────────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 8, border_width=1, border_color=tableBorderColor, bgcolor=tableBgColor)

if showTable and barstate.islast
    biasColor   = resolvedBias == "LONG" ? color.lime : resolvedBias == "SHORT" ? color.red : tableTextColor
    string logicSuffix = useFreedom ? "" : useExtreme ? " (Ext)" : " (Static)"
    anchorLabel = useFreedom ? "Freedom" : useDaily ? "Daily" + logicSuffix : "Weekly" + logicSuffix
    longStateLabel  = longState  == 0 ? "Waiting" : longState  == 1 ? "TRIGGERED" : "TP Hit"
    shortStateLabel = shortState == 0 ? "Waiting" : shortState == 1 ? "TRIGGERED" : "TP Hit"

    table.cell(infoTable, 0, 0, "Limni ADR", text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(infoTable, 1, 0, syminfo.ticker, text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(infoTable, 0, 1, "Anchor", text_color=tableTextColor, bgcolor=tableBgColor)
    color anchorColor = useFreedom ? color.new(color.yellow, 0) : useExtreme ? color.new(color.yellow, 0) : useDaily ? color.new(color.orange, 0) : tableTextColor
    table.cell(infoTable, 1, 1, anchorLabel, text_color=anchorColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 2, "Bias", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 2, resolvedBias, text_color=biasColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 3, "ADR Pips", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 3, adrReady ? str.tostring(adrPips, "#.#") + " pips" : "-", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 4, "Long ADR / TP", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 4, adrReady ? str.tostring(longEntryPrice, format.mintick) + " / " + str.tostring(longTpPrice, format.mintick) + "\nTP: " + str.tostring(longTpPips, "#.#") + " pips" : "-", text_color=color.lime, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 5, "Short ADR / TP", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 5, adrReady ? str.tostring(shortEntryPrice, format.mintick) + " / " + str.tostring(shortTpPrice, format.mintick) + "\nTP: " + str.tostring(shortTpPips, "#.#") + " pips" : "-", text_color=color.red, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 6, "Trade Status", text_color=tableTextColor, bgcolor=tableBgColor)
    string statusText = ""
    if showLong
        statusText += "L: " + longStateLabel
    if showLong and showShort
        statusText += " | "
    if showShort
        statusText += "S: " + shortStateLabel
    color statusColor = longState == 1 or shortState == 1 ? color.yellow : tableTextColor
    table.cell(infoTable, 1, 6, statusText, text_color=statusColor, bgcolor=tableBgColor)

    if isCrypto
        table.cell(infoTable, 0, 7, "Crypto Regime", text_color=tableTextColor, bgcolor=tableBgColor)
        table.cell(infoTable, 1, 7, cryptoRegime, text_color=cryptoRegime == "LONG" ? color.lime : cryptoRegime == "SHORT" ? color.red : tableTextColor, bgcolor=tableBgColor)
    else
        table.cell(infoTable, 0, 7, "", text_color=tableTextColor, bgcolor=tableBgColor)
        table.cell(infoTable, 1, 7, "", text_color=tableTextColor, bgcolor=tableBgColor)

if not showTable and barstate.islast
    table.clear(infoTable, 0, 0, 1, 7)
