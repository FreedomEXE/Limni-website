//@version=6
indicator("Limni ADR Levels", shorttitle="Limni ADR", overlay=true, format=format.price)

adrLookback = input.int(10, "ADR Lookback (days)", minval=1, maxval=50)
adrMinDays = input.int(5, "ADR Minimum Required Days", minval=1, maxval=50)
entryMultiple = input.float(1.0, "ADR Entry Multiple", minval=0.1, step=0.05)
tpMultiple = input.float(0.25, "TP ADR Multiple", minval=0.05, step=0.05)
shortPairs = input.text_area("", "SHORT Pairs (comma-sep)", tooltip="Paste bearish pairs comma-separated, e.g. USDJPY,USDCHF,EURCAD. All others default LONG.")
showTable = input.bool(true, "Show Info Table")

entryColor = input.color(color.new(color.red, 0), "ADR Level")
tpColor = input.color(color.new(color.aqua, 0), "TP Level")
tableBgColor = input.color(color.new(color.black, 15), "Table Background")
tableTextColor = input.color(color.white, "Table Text")
tableBorderColor = input.color(color.new(color.white, 45), "Table Border")

calcAdrStats() =>
    float rangeSum = 0.0
    float validCount = 0.0
    for i = 1 to adrLookback
        bool validBar = open[i] > 0 and not na(high[i]) and not na(low[i])
        if validBar
            rangeSum += ((high[i] - low[i]) / open[i]) * 100
            validCount += 1
    [rangeSum, validCount]

[dailyAdrSum, dailyAdrCount] = request.security(syminfo.tickerid, "D", calcAdrStats(), lookahead=barmerge.lookahead_off)
currentAdrPct = dailyAdrCount >= adrMinDays ? dailyAdrSum / dailyAdrCount : na

weeklyOpenSeries = request.security(syminfo.tickerid, "W", open, lookahead=barmerge.lookahead_on)
isNewWeek = ta.change(time("W")) != 0

var float weekOpenPrice = na
var float weekAdrPct = na

if barstate.isfirst or isNewWeek
    weekOpenPrice := weeklyOpenSeries
    weekAdrPct := currentAdrPct

adrReady = not na(weekOpenPrice) and not na(weekAdrPct)

// Auto-detect bias from SHORT pairs list: check if current ticker appears in the comma-separated list
tickerUpper = str.upper(syminfo.ticker)
shortList = str.upper(str.replace_all(shortPairs, " ", ""))
isShort = str.contains(shortList, tickerUpper) and str.length(tickerUpper) > 0
isBullish = not isShort
biasLabel = isBullish ? "LONG" : "SHORT"
entryDirection = isBullish ? -1.0 : 1.0
tpDirection = isBullish ? 1.0 : -1.0

entryPrice = adrReady ? weekOpenPrice * (1 + entryDirection * weekAdrPct * entryMultiple / 100) : na
tpPrice = adrReady ? entryPrice * (1 + tpDirection * weekAdrPct * tpMultiple / 100) : na

adrDistance = adrReady ? weekOpenPrice * weekAdrPct / 100 : na
pipSize = syminfo.type == "forex" ? (syminfo.currency == "JPY" ? 0.01 : 0.0001) : syminfo.mintick
adrPips = adrReady and pipSize > 0 ? adrDistance / pipSize : na

// Show current week only: plot na for all bars before the most recent week boundary
var int currentWeekStart = na
if isNewWeek
    currentWeekStart := time
showCurrentWeek = not na(currentWeekStart) and time >= currentWeekStart

plot(showCurrentWeek and adrReady ? entryPrice : na, "ADR Level", color=entryColor, style=plot.style_linebr, linewidth=2)
plot(showCurrentWeek and adrReady ? tpPrice : na, "TP Level", color=tpColor, style=plot.style_linebr, linewidth=2)

var table infoTable = table.new(position.top_right, 2, 5, border_width=1, border_color=tableBorderColor, bgcolor=tableBgColor)

if showTable and barstate.islast
    table.cell(infoTable, 0, 0, "Limni ADR", text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(infoTable, 1, 0, syminfo.ticker, text_color=tableTextColor, bgcolor=color.new(color.white, 85))
    table.cell(infoTable, 0, 1, "Bias", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 1, biasLabel, text_color=isBullish ? color.green : color.red, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 2, "ADR Pips", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 2, adrReady ? str.tostring(adrPips, "#.#") + " pips" : "-", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 3, "ADR Level", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 3, adrReady ? str.tostring(entryPrice, format.mintick) : "-", text_color=entryColor, bgcolor=tableBgColor)
    table.cell(infoTable, 0, 4, "TP", text_color=tableTextColor, bgcolor=tableBgColor)
    table.cell(infoTable, 1, 4, adrReady ? str.tostring(tpPrice, format.mintick) : "-", text_color=tpColor, bgcolor=tableBgColor)

if not showTable and barstate.islast
    table.clear(infoTable, 0, 0, 1, 4)
